{
  "version": 2,
  "builds": [
    {
      "src": "frontend/index_final.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/frontend/index_final.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Cache-Control",          "value": "public, max-age=3600" }
      ]
    }
  ]
}
